{
  "name": "canopy",
  "version": "0.1.0",
  "type": "module",
  "description": "Terminal workspace manager with split panes and git worktree isolation",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron .",
    "preview": "electron-vite preview",
    "rebuild": "electron-rebuild",
    "typecheck": "tsc --noEmit",
    "pack": "electron-vite build && electron-builder --mac --config"
  },
  "dependencies": {
    "@lydell/node-pty": "^1.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "chokidar": "^5.0.0",
    "lucide-react": "^0.562.0",
    "monaco-editor": "^0.55.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "uuid": "^13.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@electron/rebuild": "^4.0.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.22",
    "electron": "40.0.0",
    "electron-builder": "^26.4.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3"
  },
  "build": {
    "appId": "com.canopy.app",
    "productName": "Canopy",
    "directories": {
      "output": "dist",
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "src/main/shell-integration",
        "to": "shell-integration",
        "filter": ["**/*"]
      }
    ],
    "asarUnpack": [
      "out/main/node_modules/@lydell/node-pty-*/**"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
